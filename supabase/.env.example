# ─────────────────────────────────────────────────────────────
# Edge Function secrets  (template — safe to commit, holds no keys)
#
# Copy to `supabase/.env` and fill in. That file is gitignored
# (.gitignore line 3: `.env`), so real keys never reach GitHub.
#
#   cp supabase/.env.example supabase/.env
#
# ⚠️  These are SERVER-side secrets. Never move any of them into
#     `.env.local` as a VITE_* variable — Vite inlines every VITE_*
#     var into the browser bundle in plain text, where anyone can
#     read it in DevTools and drain the account.
# ─────────────────────────────────────────────────────────────

# ── OpenRouter (AI Content Brief generation) ──
# Key used by the `generate-content-brief` function.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Model slug, OpenRouter format (provider/model). Optional — defaults to
# anthropic/claude-opus-4.8. Change it here to switch models with no redeploy.
# Browse slugs at https://openrouter.ai/models
OPENROUTER_MODEL=anthropic/claude-opus-4.8

# Web research. OpenRouter's `web` plugin (Exa-backed) supplies live search
# results with the request — the stand-in for Anthropic's native web tools,
# which are not exposed through OpenRouter's OpenAI-compatible endpoint.
# Set to false to generate from the supplied links alone (cheaper, less
# accurate: the brief's RESEARCH RULES depend on real sources).
# NOTE: web results are billed by OpenRouter per request, on top of tokens.
OPENROUTER_WEB_SEARCH=true
OPENROUTER_WEB_MAX_RESULTS=8

# Sent as the HTTP-Referer attribution header to OpenRouter. Optional.
OPENROUTER_SITE_URL=https://afflixmedia.com

# Google Drive folder that receives CONTENT BRIEF images (uploaded logos and
# any image placed in a brief). Brief TEXT lives in Postgres; images live on
# Drive, same model as chat attachments.
#
# Optional: if unset, `brief-drive-upload` falls back to GDRIVE_FOLDER_ID (the
# chat-uploads folder), so it works without extra setup. Set it to keep brief
# images in their own folder.
#
# The GDRIVE_CLIENT_ID / GDRIVE_CLIENT_SECRET / GDRIVE_REFRESH_TOKEN secrets
# are already configured for chat uploads and are reused as-is.
GDRIVE_BRIEF_FOLDER_ID=

# ── How these reach the deployed functions ──
# `supabase/.env` is only used for LOCAL runs:
#   supabase functions serve generate-content-brief --env-file ./supabase/.env
#
# For DEPLOYED functions you must push the secrets to Supabase once:
#   supabase secrets set OPENROUTER_API_KEY=sk-or-v1-...
#   supabase secrets set OPENROUTER_MODEL=anthropic/claude-opus-4.8
# or set them in the Dashboard: Project Settings → Edge Functions → Secrets.
#
# Then deploy:
#   supabase functions deploy generate-content-brief
#   supabase functions deploy brief-drive-upload
#   supabase functions deploy get-shared-brief --no-verify-jwt
